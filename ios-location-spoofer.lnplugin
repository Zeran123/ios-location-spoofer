#!name=iOS Location Spoofer
#!desc=拦截 Apple 定位服务回传的坐标资料并置换为指定位置。Loon 专用。
#!homepage=https://github.com/mekos2772/ios-location-spoofer

[Script]
http-response ^https?:\/\/(?:gs-loc(?:-cn)?\.apple\.com|bluedot\.is\.autonavi\.com(?:\.gds\.alibabadns\.com)?)\/clls\/wloc(?:\?.*)?$ script-path=https://raw.githubusercontent.com/mekos2772/ios-location-spoofer/main/location-spoofer.js, requires-body=true, binary-body-mode=true, timeout=10, tag=iOS Location Spoofer

[MITM]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com, bluedot.is.autonavi.com, bluedot.is.autonavi.com.gds.alibabadns.com
